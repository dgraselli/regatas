# Usa datos de ejemplo (fixtures) en lugar de llamar a las APIs reales.
# true  -> ideal para desarrollo offline, build y tests (sin red).
# false -> el navegador llama a Open-Meteo / INA en runtime.
NEXT_PUBLIC_USE_MOCKS=true

# Analítica anónima sin cookies (Umami). Dejalas vacías para desactivarla.
# SRC: URL del script (Umami Cloud: https://cloud.umami.is/script.js, o tu instancia).
# WEBSITE_ID: el id del sitio que te da Umami.
NEXT_PUBLIC_UMAMI_SRC=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# Formulario externo de feedback (ej. Tally). Vacío = no se muestra el botón.
NEXT_PUBLIC_FEEDBACK_URL=
